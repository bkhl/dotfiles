{
  "base_keymap": "VSCode",
  "ui_font_family": "Inter BKHL Variable",
  "buffer_font_family": "Iosevka BKHL Sans Normal",
  "session": {
    "restore_unsaved_buffers": true,
    "trust_all_worktrees": false,
  },
  "restore_on_startup": "launchpad",
  "ui_font_size": 18.0,
  "buffer_font_size": 16.0,
  "agent_buffer_font_size": 18.0,
  "theme": {
    "mode": "system",
    "light": "Modus Operandi",
    "dark": "Modus Vivendi Tritanopia",
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle",
    "provider": "copilot",
  },
  "auto_update": true,
  "auto_install_extensions": {
    "ansible": true,
    "basher": true,
    "csv": true,
    "dockerfile": true,
    "git-firefly": true,
    "github-actions": true,
    "helm": true,
    "html": true,
    "ini": true,
    "lua": true,
    "make": true,
    "modus-themes": true,
    "perl": true,
    "scss": true,
    "sql": true,
    "terraform": true,
    "toml": true,
    "xml": true,
  },
}
