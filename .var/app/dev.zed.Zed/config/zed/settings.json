{
  "base_keymap": "VSCode",
  "ui_font_family": "Inter BKHL Variable",
  "buffer_font_family": "Iosevka BKHL Sans Normal",
  "auto_update": false,
  "session": {
    "trust_all_worktrees": true,
  },
  "ui_font_size": 18.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "Modus Operandi",
    "dark": "Modus Vivendi Tritanopia",
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle",
    "provider": "copilot",
  },
  "auto_install_extensions": {
    "ansible": true,
    "csv": true,
    "dockerfile": true,
    "git-firefly": true,
    "github-actions": true,
    "helm": true,
    "html": true,
    "lua": true,
    "make": true,
    "modus-themes": true,
    "perl": true,
    "xml": true,
  },
}
