#!/usr/bin/env python3

"""
Fix StartupWMClass in Vivaldi and Microsoft Edge app (.desktop) launchers.

These, and I guess other Chromium derived browsers, regenerates the .desktop
files for installed web apps and resets the StartupWMClass to a value that no
longer matches the window's actual WM_CLASS, which breaks taskbar icon
grouping. The correct value is the Icon= value with an underscore inserted
right after the first hyphen, e.g.:

    Icon=vivaldi-dhmcgdjoiiejjlpmbpgdbkfhjbhomgfm-Default
    StartupWMClass=vivaldi-_dhmcgdjoiiejjlpmbpgdbkfhjbhomgfm-Default

Fixes all vivaldi-*.desktop and msedge-*.desktop files in ~/.local/share/applications.
"""

import configparser
import sys
from pathlib import Path

APPLICATIONS_DIR = Path.home() / ".local" / "share" / "applications"


def desired_wmclass(icon_value):
    head, sep, tail = icon_value.partition("-")
    if not sep:
        return None
    if head not in ("msedge", "vivaldi"):
        return None
    return f"{head}-_{tail}"


def fix_file(path):
    cfg = configparser.ConfigParser(interpolation=None, delimiters="=")
    cfg.optionxform = str
    try:
        cfg.read(path, encoding="utf-8")
    except (OSError, configparser.Error):
        return

    if not cfg.has_section("Desktop Entry"):
        return

    section = cfg["Desktop Entry"]
    icon_value = section.get("Icon")
    if icon_value is None:
        return

    wanted = desired_wmclass(icon_value)
    if wanted is None:
        return

    if section.get("StartupWMClass") == wanted:
        return

    section["StartupWMClass"] = wanted
    with path.open("w", encoding="utf-8") as f:
        cfg.write(f, space_around_delimiters=False)


def main():
    targets = sorted(APPLICATIONS_DIR.glob("*-*.desktop"))
    if not targets:
        return 1

    for path in targets:
        fix_file(path)

    return 0


if __name__ == "__main__":
    sys.exit(main())
